    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "21.1.0",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-server": "^21.0.6",
    "@angular/ssr": "21.1.0",
    "@tailwindcss/postcss": "^4.1.12",
